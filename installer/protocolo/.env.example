# ── Alphafitus — Configuração Local ─────────────────────────────
  # Copie este arquivo para .env e ajuste os valores antes de instalar.

  # Senha do banco de dados (mude para algo seguro!)
  DB_PASSWORD=alphafitus2024

  # Chave de sessão (qualquer texto longo e aleatório)
  SESSION_SECRET=mude_esta_chave_para_algo_bem_longo_e_aleatorio

  # Senha do usuário administrador mestre
  MASTER_PASSWORD=admin123

  # Porta HTTP (padrão 80 — não mude se não souber)
  HTTP_PORT=80

  # Caminho da pasta do Google Drive para backup automático
  # Exemplo Windows: C:/Users/SeuNome/Google Drive/My Drive/Alphafitus-Backup
  GOOGLE_DRIVE_PATH=C:/Users/Public/GoogleDrive/Alphafitus-Backup
  